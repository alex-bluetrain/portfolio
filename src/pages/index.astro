---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import Timeline from '../components/Timeline.astro';
import Footer from '../components/Footer.astro';

const milestones = await getCollection('milestones');
---

<Layout>
	<Header />
	<Hero />

	<section class="section container" id="timeline">
		<h2 class="section-title">Sim Racing</h2>
		<p class="section-subtitle">
			<!-- TODO: short intro for this section -->
			Every milestone, in chronological order: from the first DIY parts to the latest
			hardware, firmware, and software iterations.
		</p>
		<Timeline milestones={milestones} />
	</section>

	<Footer />
</Layout>
