---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Gallery from '../../components/Gallery.astro';
import VideoBlock from '../../components/VideoBlock.astro';
import SpecsTable from '../../components/SpecsTable.astro';
import Footer from '../../components/Footer.astro';
import { withBase } from '../../lib/paths';

export async function getStaticPaths() {
	const milestones = await getCollection('milestones');
	return milestones.map((milestone) => ({
		params: { slug: milestone.id },
		props: { milestone },
	}));
}

const { milestone } = Astro.props;
const { title, date, category, status, cover, images, videos, specs, tags } = milestone.data;
const { Content } = await render(milestone);

const statusLabel: Record<string, string> = {
	completed: 'Completed',
	'in-progress': 'In progress',
	iterating: 'Iterating',
};

const categoryLabel: Record<string, string> = {
	hardware: 'Hardware',
	electronics: 'Electronics',
	firmware: 'Firmware',
	software: 'Software',
};

const formattedDate = date.toLocaleDateString('en-US', { month: 'long', year: 'numeric' });
---

<Layout title={`${title} — Portfolio`}>
	<Header />

	<article class="section container detail">
		<a class="back-link" href={withBase('#timeline')}>&larr; Back to the timeline</a>

		<h1 class="detail__title">{title}</h1>

		{videos.length > 0 && (
			<div class="detail__block detail__block--videos">
				<VideoBlock videos={videos} />
			</div>
		)}

		<div class="detail__cover">
			<img src={withBase(cover)} alt={title} />
		</div>

		<div class="detail__content">
			<Content />
		</div>

		{specs.length > 0 && (
			<div class="detail__block">
				<h2>Specs</h2>
				<SpecsTable specs={specs} />
			</div>
		)}

		{images.length > 0 && (
			<div class="detail__block">
				<h2>Photos</h2>
				<Gallery images={images} />
			</div>
		)}
	</article>

	<Footer />
</Layout>

<style>
	.detail {
		max-width: 820px;
	}

	.back-link {
		display: inline-block;
		text-decoration: none;
		color: var(--text-muted);
		margin-bottom: 24px;
		font-size: 0.9rem;
	}

	.back-link:hover {
		color: var(--text);
	}

	.detail__meta {
		display: flex;
		align-items: center;
		gap: 12px;
		margin-bottom: 12px;
	}

	.detail__title {
		font-size: clamp(1.8rem, 4vw, 2.6rem);
		margin-bottom: 12px;
	}

	.detail__tags {
		display: flex;
		gap: 8px;
		margin-bottom: 24px;
	}

	.tag {
		font-size: 0.75rem;
		color: var(--text-muted);
		background: rgba(255, 255, 255, 0.05);
		padding: 3px 10px;
		border-radius: 999px;
	}

	.detail__cover {
		border-radius: var(--radius);
		overflow: hidden;
		border: 1px solid var(--border);
		margin-bottom: 32px;
	}

	.detail__content {
		margin-bottom: 56px;
		line-height: 1.7;
	}

	.detail__content :global(p) {
		font-size: 1.02rem;
		margin-bottom: 1.2em;
	}

	.detail__block {
		margin-bottom: 56px;
		padding-top: 40px;
		border-top: 1px solid var(--border);
	}

	.detail__block:first-of-type {
		padding-top: 0;
		border-top: none;
	}

	.detail__block h2 {
		font-size: 1.35rem;
		margin-bottom: 24px;
		color: #fff;
		letter-spacing: -0.01em;
	}

	.detail__block--videos {
		margin-bottom: 56px;
		padding-top: 0;
		border-top: none;
	}
</style>
