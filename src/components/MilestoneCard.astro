---
import type { CollectionEntry } from 'astro:content';

interface Props {
	milestone: CollectionEntry<'milestones'>;
}

const { milestone } = Astro.props;
const { title, date, category, status, summary, cover, tags } = milestone.data;

const categoryLabel: Record<string, string> = {
	hardware: 'Hardware',
	electronica: 'Electrónica',
	firmware: 'Firmware',
	software: 'Software',
};

const statusLabel: Record<string, string> = {
	completado: 'Completado',
	'en-progreso': 'En progreso',
	iterando: 'Iterando',
};

const formattedDate = date.toLocaleDateString('es-AR', { month: 'short', year: 'numeric' });
---

<a class="card milestone-card" href={`/proyecto/${milestone.id}`}>
	<div class="milestone-card__cover">
		<img src={cover} alt={title} loading="lazy" />
	</div>
	<div class="milestone-card__body">
		<div class="milestone-card__meta">
			<span class={`badge badge--${category}`}>{categoryLabel[category]}</span>
			<span class="status">{formattedDate}</span>
		</div>
		<h3 class="milestone-card__title">{title}</h3>
		<p class="milestone-card__summary">{summary}</p>
		<div class="milestone-card__footer">
			<span class="status">{statusLabel[status]}</span>
			{tags.length > 0 && (
				<div class="milestone-card__tags">
					{tags.slice(0, 3).map((tag) => <span class="tag">{tag}</span>)}
				</div>
			)}
		</div>
	</div>
</a>

<style>
	.milestone-card {
		display: flex;
		flex-direction: column;
		text-decoration: none;
		color: inherit;
		transition: transform 0.15s ease, border-color 0.15s ease;
	}

	.milestone-card:hover {
		transform: translateY(-3px);
		border-color: var(--accent);
	}

	.milestone-card__cover {
		aspect-ratio: 16 / 10;
		overflow: hidden;
		background: var(--bg-alt);
	}

	.milestone-card__cover img {
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	.milestone-card__body {
		padding: 18px 20px 20px;
		display: flex;
		flex-direction: column;
		gap: 8px;
		flex: 1;
	}

	.milestone-card__meta {
		display: flex;
		align-items: center;
		justify-content: space-between;
	}

	.milestone-card__title {
		font-size: 1.1rem;
		margin: 0;
	}

	.milestone-card__summary {
		font-size: 0.9rem;
		margin: 0;
		flex: 1;
	}

	.milestone-card__footer {
		display: flex;
		align-items: center;
		justify-content: space-between;
		margin-top: 8px;
	}

	.milestone-card__tags {
		display: flex;
		gap: 6px;
	}

	.tag {
		font-size: 0.7rem;
		color: var(--text-muted);
		background: rgba(255, 255, 255, 0.05);
		padding: 2px 8px;
		border-radius: 999px;
	}
</style>
