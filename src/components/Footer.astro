</footer>

<style>
	.footer {
		border-top: 1px solid var(--border);
		background: var(--bg-alt);
		padding: 56px 0 24px;
	}

	.footer__inner {
		display: flex;
		flex-wrap: wrap;
		gap: 32px;
		justify-content: space-between;
		margin-bottom: 32px;
	}

	.footer__inner h3 {
		margin-bottom: 8px;
	}

	.footer__inner p {
		max-width: 420px;
	}

	.footer__links {
		display: flex;
		flex-direction: column;
		gap: 8px;
	}

	.footer__links a {
		text-decoration: none;
		color: var(--text-muted);
	}

	.footer__links a:hover {
		color: var(--text);
	}

	.footer__legal {
		border-top: 1px solid var(--border);
		padding-top: 16px;
	}

	.footer__legal p {
		font-size: 0.8rem;
		margin: 0;
	}
</style>
