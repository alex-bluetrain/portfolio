<footer class="footer" id="contacto">
	<div class="container footer__inner">
		<div>
			<h3>Let's talk</h3>
			<p>
				<!-- TODO: contact message -->
				Happy to share technical details, code, or plans for any part of the project.
			</p>
		</div>
		<div class="footer__links">
			<!-- TODO: replace with your real links -->
			<a href="mailto:your@email.com">Email</a>
			<a href="https://github.com/your-username" target="_blank" rel="noreferrer">GitHub</a>
			<a href="https://linkedin.com/in/your-username" target="_blank" rel="noreferrer">LinkedIn</a>
			<a href="https://youtube.com/@your-channel" target="_blank" rel="noreferrer">YouTube</a>
