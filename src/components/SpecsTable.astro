---
interface Spec {
	label: string;
	value: string;
}

interface Props {
	specs: Spec[];
}

const { specs } = Astro.props;
---

{specs.length > 0 && (
	<dl class="specs">
		{specs.map((spec) => (
			<div class="specs__row">
				<dt>{spec.label}</dt>
				<dd>{spec.value}</dd>
			</div>
		))}
	</dl>
)}

<style>
	.specs {
		border: 1px solid var(--border);
		border-radius: var(--radius);
		overflow: hidden;
		margin: 0;
	}

	.specs__row {
		display: grid;
		grid-template-columns: 200px 1fr;
		padding: 12px 16px;
		font-size: 0.9rem;
	}

	.specs__row:not(:last-child) {
		border-bottom: 1px solid var(--border);
	}

	.specs__row dt {
		color: var(--text-muted);
	}

	.specs__row dd {
		margin: 0;
	}

	@media (max-width: 480px) {
		.specs__row {
			grid-template-columns: 1fr;
			gap: 4px;
		}
	}
</style>
