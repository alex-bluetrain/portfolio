---
const videoId = '25QNes8U1u4';
const embedParams = new URLSearchParams({
	autoplay: '1',
	mute: '1',
	loop: '1',
	playlist: videoId,
	start: '8',
	controls: '0',
	showinfo: '0',
	modestbranding: '1',
	rel: '0',
	disablekb: '1',
	fs: '0',
	iv_load_policy: '3',
	playsinline: '1',
});
const embedUrl = `https://www.youtube-nocookie.com/embed/${videoId}?${embedParams.toString()}`;
---

<section class="hero">
	<div class="hero__video" aria-hidden="true">
		<iframe
			src={embedUrl}
			title=""
			tabindex="-1"
			frameborder="0"
			allow="autoplay; encrypted-media"
		></iframe>
	</div>
	<div class="hero__overlay" aria-hidden="true"></div>

	<div class="container hero__inner">
		<p class="hero__eyebrow">Personal project · building since 2011</p>
		<h1 class="hero__title">
			<!-- TODO: your simulator's actual name/title -->
			Building my racing simulator, piece by piece
		</h1>
		<p class="hero__subtitle">
			<!-- TODO: 2-3 lines on the project's motivation: why you started it, what you
			wanted to simulate, what you started with (generic wheel, a living-room chair,
			etc.), and where it stands today. -->
			This is the record of how a simulator built with whatever I had on hand turned
			into a full cockpit: every piece of hardware, every firmware, and every version
			of software I built with my own two hands.
		</p>
		<div class="hero__actions">
			<a class="button" href="#timeline">See the evolution</a>
			<a class="button button--ghost" href="#contacto">Contact</a>
		</div>
	</div>
</section>

<style>
	.hero {
		position: relative;
		isolation: isolate;
		overflow: hidden;
		padding: 96px 0 64px;
		border-bottom: 1px solid var(--border);
		/* Fallback visible mientras carga el video (y si no carga) */
		background:
			linear-gradient(180deg, rgba(10, 10, 10, 0.82), rgba(10, 10, 10, 0.92)),
			url('/images/simracing-rig.jpg') center 30% / cover no-repeat;
	}

	.hero__inner {
		position: relative;
		z-index: 2;
	}

	.hero__video {
		position: absolute;
		inset: 0;
		z-index: 0;
		pointer-events: none;
		overflow: hidden;
	}

	/*
	 * El iframe de YouTube es 16:9 fijo: lo escalamos al mayor de
	 * 100vw/100vh manteniendo ratio para cubrir el hero (efecto object-fit: cover).
	 * El encuadre vertical se controla con --hero-video-anchor: usando
	 * `top: k` + `translateY(-k)` el desplazamiento queda en -k * (altoVideo - altoHero),
	 * así que 0% = anclado arriba, 50% = centrado, 25% = punto medio entre ambos.
	 */
	.hero__video iframe {
		--hero-video-anchor: 25%;
		position: absolute;
		top: var(--hero-video-anchor);
		left: 50%;
		width: 100vw;
		height: 56.25vw; /* 100vw / (16/9) */
		min-height: 100%;
		min-width: 177.78vh; /* 100vh * (16/9) */
		transform: translate(-50%, calc(-1 * var(--hero-video-anchor)));
		border: 0;
	}

	.hero__overlay {
		position: absolute;
		inset: 0;
		z-index: 1;
		pointer-events: none;
		/* Neutro a propósito: cualquier gradiente de color tiñe el video de abajo */
		background: linear-gradient(180deg, rgba(10, 10, 10, 0.72), rgba(10, 10, 10, 0.88));
	}

	@media (prefers-reduced-motion: reduce) {
		.hero__video {
			display: none;
		}
	}

	.hero__eyebrow {
		color: var(--accent);
		font-family: var(--font-mono);
		font-size: 0.8rem;
		font-weight: 500;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		margin-bottom: 16px;
	}

	.hero__title {
		color: #fff;
		font-size: clamp(2.2rem, 5.5vw, 3.6rem);
		max-width: 760px;
		letter-spacing: -0.01em;
	}

	.hero__subtitle {
		color: rgba(255, 255, 255, 0.85);
		max-width: 620px;
		font-size: 1.05rem;
		margin-bottom: 32px;
	}

	.hero__actions {
		display: flex;
		gap: 16px;
		flex-wrap: wrap;
	}
</style>
